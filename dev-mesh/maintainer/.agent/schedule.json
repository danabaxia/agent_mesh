{
  "jobs": [
    {
      "id": "label-repair-sweep",
      "name": "Label repair sweep",
      "kind": "builtin",
      "builtin": "label-repair-sweep",
      "cadence": { "kind": "every", "minutes": 10 },
      "enabled": true
    },
    {
      "id": "issue-sweep",
      "name": "Label-aware issue sweep",
      "kind": "builtin",
      "builtin": "issue-sweep",
      "cadence": { "kind": "every", "minutes": 10 },
      "enabled": true
    },
    {
      "id": "automerge-sweep",
      "name": "Prompt drain — merge CLEAN+APPROVED PRs",
      "kind": "builtin",
      "builtin": "automerge-sweep",
      "cadence": { "kind": "every", "minutes": 10 },
      "enabled": true
    },
    {
      "id": "merge-sweep",
      "name": "Merge sweep (report-only)",
      "kind": "builtin",
      "builtin": "merge-sweep",
      "cadence": { "kind": "every", "minutes": 15 },
      "enabled": true,
      "description": "Read-only inspect: issue-gate -> automerge -> memory; writes mesh/reports/merge-sweep.json. No merges/labels."
    },
    {
      "id": "merge-sweep-remediate",
      "name": "Merge-sweep remediation (backstop)",
      "kind": "builtin",
      "builtin": "merge-sweep-remediate",
      "cadence": { "kind": "every", "minutes": 30 },
      "enabled": true,
      "description": "Backstop: escalate report items the fixers couldn't clear as deduped needs-human issues; track lifecycle. No code changes."
    },
    {
      "id": "post-merge-reconcile",
      "name": "Close issues whose closing PR merged (clear stale pr:in-review)",
      "kind": "builtin",
      "builtin": "post-merge-reconcile",
      "cadence": { "kind": "every", "minutes": 10 },
      "enabled": true
    },
    {
      "id": "autofix-pr-sweep",
      "name": "Escalate bug-autofix PRs closed without merging (pr:in-review → blocked)",
      "kind": "builtin",
      "builtin": "autofix-pr-sweep",
      "cadence": { "kind": "every", "minutes": 10 },
      "enabled": true
    }
  ]
}
